{
  "name": "project_rbac",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "dotenvx run --convention nextjs -- next dev",
    "build": "cross-env NODE_ENV=production dotenvx run --convention nextjs -- next build",
    "start": "NODE_ENV=production dotenvx run --convention nextjs -- next start",
    "lint": "biome check",
    "format": "biome format --write",
    "env:encrypt": "dotenvx encrypt -f .env.development -f .env.production",
    "env:decrypt": "dotenvx decrypt -f .env.development -f .env.production",
    "prepare": "husky",
    "db:generate": "dotenvx run -f .env.development -- drizzle-kit generate",
    "db:migrate": "dotenvx run -f .env.development -- drizzle-kit migrate",
    "db:studio": "dotenvx run -f .env.development -- drizzle-kit studio",
    "seed": "dotenvx run -f .env.development -- tsx src/scripts/seed-admin.ts"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.23",
    "@dotenvx/dotenvx": "^1.75.1",
    "@neondatabase/serverless": "^1.1.0",
    "better-auth": "^1.6.23",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.43",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
